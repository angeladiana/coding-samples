*Generating dummies
{
generate privatepension = 1 if pensionp == 1
replace privatepension = 0 if pensionp == 2
label var privatepension "Pension (Private)"
label define privatepension 0 "No Pension (Private)"
label define privatepension 1 "With Pension (Private)", add
label values privatepension privatepension

generate publicpension = 1 if pensiong == 1
replace publicpension = 0 if pensiong == 2
label var publicpension "Pension (Gov't)"
label define publicpension 0 "No Pension (Gov't)"
label define publicpension 1 "With Pension (Gov't)", add
label values publicpension publicpension

generate hhjob = 0
replace hhjob = 1 if job == 1
label var hhjob "Household Head Job or Business Indicator"
label define hhjob 0 "HH Head: No Job"
label define hhjob 1 "HH Head: With Job", add
label values hhjob hhjob

generate spousejob = 0
replace spousejob = 1 if spouse_emp == 1
label var spousejob "Spouse has job/business"
label define spousejob 0 "Spouse: No Job"
label define spousejob 1 "Spouse: With Job", add
label values spousejob spousejob

gen hhsex = sex
replace hhsex = 0 if sex == 2
label var hhsex "Household Head Sex"
label define hhsex 0 "Female Household Head"
label define hhsex 1 "Male Household Head", add
label values hhsex hhsex

gen college = 0
replace college=1 if hgc_recode>=8
label var college "College-educated Head"
label define college 0 "HH Head HGC is Below College Level"
label define college 1 "HH Head HGC is College Level or Above", add
label values college college

gen cashabroad = 0
replace cashabroad = 1 if cash_abroad>0
label var cashabroad "Cash Receipts, Support, etc. from Abroad"
label define cashabroad 0 "No remittance (abroad)"
label define cashabroad 1 "With remittance (abroad)", add
label values cashabroad cashabroad

gen cashdomestic = 0
replace cashdomestic = 1 if cash_domestic>0
label var cashdomestic "Cash Receipts, Support, etc. from Domestic Source"
label define domestic 0 "No remittance (domestic)"
label define cashdomestic 1 "With remittance (domestic)", add
label values cashdomestic cashdomestic

gen rentalsrec = 0
replace rentalsrec = 1 if rentals_rec>0
label var rentalsrec "Rentals Received from Non-Agri Lands, etc."
label define rentalsrec 0 "No rentals received"
label define rentalsrec 1 "With rentals received", add
label values rentalsrec rentalsrec

gen minsrpension = 0
replace minsrpension = 1 if minsr == 19
label var minsrpension "Main Source of Income is Pension"
label define minsrpension 0 "Other Sources of Income"
label define minsrpension 1 "Main Source of Income is Pension", add
label values minsrpension minsrpension

gen urban = 0
replace urban = 1 if urb == 1
label var urban "Urban/Rural"
label define urban 0 "Rural"
label define urban 1 "Urban", add
label values urban urban
}

